# Copy to `.env.local` for local Vite development or configure in Vercel.

# Browser -> API gateway GraphQL endpoint.
VITE_GRAPHQL_HTTP=http://localhost:4000/graphql
VITE_GRAPHQL_WS=ws://localhost:4000/graphql

# Optional bearer token for protected gateway requests.
VITE_GRAPHQL_TOKEN=

# Deployment placeholders.
# VITE_GRAPHQL_HTTP=https://your-api-gateway.example.com/graphql
# VITE_GRAPHQL_WS=wss://your-api-gateway.example.com/graphql
