# Copy to `.env` for local quantum-sim development.

# FastAPI HTTP port is supplied by the process/server command.
# Docker Compose maps this service to 8002 by default.
HTTP_PORT=8002

# gRPC entropy service port.
QUANTUM_GRPC_PORT=50052
GRPC_PORT=50052

# Optional deployment placeholder.
QUANTUM_SIM_API_URL=https://your-quantum-sim-api.example.com
