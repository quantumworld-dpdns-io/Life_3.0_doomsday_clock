# Copy to `.env` for local intelligence-service development.

# Local Docker Postgres.
DATABASE_URL=postgres://life3:life3@localhost:5432/life3

# Supabase shared transaction pooler placeholder.
# DATABASE_URL=postgresql://postgres.your-project-ref:YOUR_URL_ENCODED_PASSWORD@aws-1-your-region.pooler.supabase.com:6543/postgres?sslmode=require

# Admin key accepted by POST /scrape/trigger.
ADMIN_API_KEY=change-me

# LLM configuration. Use OpenAI or set USE_OLLAMA=true for local Ollama.
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
USE_OLLAMA=false

# Service ports and scheduler.
HTTP_PORT=8001
GRPC_PORT=50051
SCRAPE_INTERVAL_MINUTES=15
