# Copy to `.env` for local gateway development or configure in Render/Vercel.

# HTTP bind address for the gateway.
API_GATEWAY_ADDR=:4000

# Login API key used by POST /auth/login.
API_GATEWAY_API_KEY=change-me

# JWT signing secret. Use a long random value in production.
API_GATEWAY_JWT_SECRET=change-me
JWT_SECRET=change-me

# Upstream services. Names are kept for current compatibility even though
# the gateway MVP uses HTTP upstreams.
RISK_ENGINE_GRPC_ADDR=http://localhost:8003
INTELLIGENCE_GRPC_ADDR=http://localhost:8001

# Deployment placeholders.
# RISK_ENGINE_GRPC_ADDR=https://your-risk-engine-api.example.com
# INTELLIGENCE_GRPC_ADDR=https://your-intelligence-api.example.com
