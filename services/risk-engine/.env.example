# Copy to `.env` for local risk-engine development.

# HTTP and gRPC ports.
HTTP_PORT=8003
GRPC_PORT=50053

# Upstream services used for clock computation.
INTELLIGENCE_ADDR=http://localhost:8001
QUANTUM_ADDR=http://localhost:8002

# Logging.
RUST_LOG=info

# Deployment placeholders.
# INTELLIGENCE_ADDR=https://your-intelligence-api.example.com
# QUANTUM_ADDR=https://your-quantum-sim-api.example.com
