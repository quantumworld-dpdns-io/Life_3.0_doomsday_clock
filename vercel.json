{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "bash -c 'p=shared/scripts/vercel_install_web.sh; [ -f $p ] || p=../../$p; bash $p'",
  "buildCommand": "bash -c 'p=shared/scripts/vercel_build_web.sh; [ -f $p ] || p=../../$p; bash $p'",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
