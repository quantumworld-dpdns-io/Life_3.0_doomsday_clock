# Copy to .env for local development.

# Shared database settings used by Docker Compose.
POSTGRES_USER=life3
POSTGRES_PASSWORD=life3
POSTGRES_DB=life3
POSTGRES_PORT=5432

# Host-side migration/test connection string.
# Local Docker Postgres:
DATABASE_URL=postgres://life3:life3@localhost:5432/life3
#
# Supabase shared transaction pooler:
# DATABASE_URL=postgresql://postgres.meslvfoeoduhbsawgawz:YOUR_URL_ENCODED_PASSWORD@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?sslmode=require

# Intelligence service LLM configuration.
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434
USE_OLLAMA=false
SCRAPE_INTERVAL_MINUTES=15

# Published local ports.
INTELLIGENCE_HTTP_PORT=8001
INTELLIGENCE_GRPC_PORT=50051
QUANTUM_HTTP_PORT=8002
QUANTUM_GRPC_PORT=50052
RISK_HTTP_PORT=8003
RISK_GRPC_PORT=50053
API_GATEWAY_PORT=4000
API_GATEWAY_API_KEY=dev-api-key
WEB_PORT=3000
NATS_PORT=4222
NATS_HTTP_PORT=8222

JWT_SECRET=change-me-for-local-dev
ENABLE_NATS=false

# Local frontend -> local gateway.
VITE_GRAPHQL_HTTP=http://localhost:4000/graphql
VITE_GRAPHQL_WS=ws://localhost:4000/graphql

# Public deployment URL placeholders.
# Replace these with your Vercel/Render/custom-domain endpoints per environment.
API_GATEWAY_URL=https://your-api-gateway.example.com
INTELLIGENCE_API_URL=https://your-intelligence-api.example.com
QUANTUM_SIM_API_URL=https://your-quantum-sim-api.example.com
RISK_ENGINE_API_URL=https://your-risk-engine-api.example.com

# API gateway upstreams. These names are kept for current gateway compatibility.
RISK_ENGINE_GRPC_ADDR=https://your-risk-engine-api.example.com
INTELLIGENCE_GRPC_ADDR=https://your-intelligence-api.example.com

# Risk-engine upstreams.
INTELLIGENCE_ADDR=https://your-intelligence-api.example.com
QUANTUM_ADDR=https://your-quantum-sim-api.example.com

# Optional DNS CNAME labels. Add your zone suffix when using full hostnames.
API_GATEWAY_CNAME=your-api-gateway-cname
INTELLIGENCE_API_CNAME=your-intelligence-api-cname
QUANTUM_SIM_API_CNAME=your-quantum-sim-api-cname
RISK_ENGINE_API_CNAME=your-risk-engine-api-cname
